# =============================================================
# Altiplano Resiliente - Environment Variables Template
# DO NOT commit real secrets. Run setup.bat to generate .env
# =============================================================
#
# RUTAS PORTABLES CON ONEDRIVE (IUCN)
# -------------------------------------------------------------
# Todas las rutas locales de este proyecto se escriben en
# relacion a OneDrive de IUCN usando el marcador ${ONEDRIVE_IUCN}.
#
# Al arrancar el servidor, env_paths.py detecta automaticamente la
# carpeta "OneDrive - IUCN..." bajo %USERPROFILE% y reemplaza
# ${ONEDRIVE_IUCN} por la ruta real de ESTE PC (E:\, C:\, D:\, ...).
# Asi, el mismo .env funciona en cualquier computador del equipo
# sin reescribir las letras de unidad.
#
# / Todas las rutas usan ${ONEDRIVE_IUCN}; el servidor lo expande
#   a la carpeta real "OneDrive - IUCN..." de cada PC.
#
# Override manual (solo si la deteccion automatica falla):
#   descomente la linea siguiente y ponga la ruta exacta de su
#   carpeta OneDrive de IUCN en este PC.
# ONEDRIVE_IUCN=E:\OneDrive - IUCN International Union for Conservation of Nature

# --- ArcGIS Online ------------------------------------------------
# ARCGIS_ORG_URL: Optional default — can also enter in dashboard UI.
ARCGIS_ORG_URL=https://iucn.maps.arcgis.com
#
# ARCGIS_CLIENT_ID: Required for OAuth login.
# How to get it / Cómo obtenerlo:
#   1. Go to AGOL → Content → New Item → Application (type: Other)
#   2. In the app settings, add Redirect URI:
#      http://localhost:5000/oauth/callback
#   3. Copy the Client ID (AppID) here.
ARCGIS_CLIENT_ID=
#
ARCGIS_API_KEY=

# --- AGOL Feature Layer Item IDs (find in AGOL item page URL) -
# Example: https://iucn.maps.arcgis.com/home/item.html?id=abc123...
# The 32-character hex string after ?id= is the Item ID.
AGOL_POLYGON_ITEM_ID=
AGOL_POINT_ITEM_ID=

# --- AGOL Feature Layer URLs (fallback when Item IDs are not set) -
AGOL_POLYGON_URL=
AGOL_POINT_URL=

# --- Smartsheet (shared across team) -------------------------
SMARTSHEET_TOKEN=REPLACE_WITH_SMARTSHEET_TOKEN
SHEET_C1=REPLACE_WITH_SHEET_ID_C1
SHEET_C2=
SHEET_C3=
DEFAULT_COMPONENT=C1
ROW_START=1
ROW_END=100

# --- Local paths (relative to OneDrive IUCN) -----------------
# Todas estas rutas usan ${ONEDRIVE_IUCN}. Ajuste las subcarpetas
# (AR\...) al arbol real de su OneDrive de IUCN.
# / Estas rutas se basan en ${ONEDRIVE_IUCN}; el servidor las expande
#   a la ruta real de este PC.
#
# Carpetas de descarga de adjuntos por componente
FOLDER_C1=${ONEDRIVE_IUCN}\AR\C1
FOLDER_C2=${ONEDRIVE_IUCN}\AR\C2
FOLDER_C3=${ONEDRIVE_IUCN}\AR\C3
#
# Carpetas de datos y adjuntos de Smartsheet
SMARTSHEET_DATA_DIR=${ONEDRIVE_IUCN}\AR\1. Smartsheet data
SMARTSHEET_ATTACH_DIR=${ONEDRIVE_IUCN}\AR\2. Smartsheet attachment
#
# Base de datos oficial (Excel)
EXCEL_DB_DIR=${ONEDRIVE_IUCN}\AR\0. Database_oficial
#
# Carpeta de salida de comparaciones raster (notebook 1_3_DynamicDir)
RASTER_OUTPUT_DIR=${ONEDRIVE_IUCN}\AR\IA\IA_Insumos_BL\Output\RasterComparisons

# --- ArcGIS Pro (auto-detected by setup.bat) -----------------
# Re-run setup.bat after installing a new ArcGIS Pro version
# ARCPY_PYTHON: full path to python.exe in your ArcGIS Pro conda env
# Example: C:\Program Files\ArcGIS\Pro\bin\Python\envs\arcgispro-py3\python.exe
ARCPY_PYTHON=
ARCGIS_PRO_VERSION=

# --- ArcGIS Pro project paths (relative to OneDrive IUCN) ----
# Rutas del proyecto ArcGIS Pro, tambien basadas en ${ONEDRIVE_IUCN}.
# Ajuste las subcarpetas al arbol real de su OneDrive de IUCN.
WORKSPACE_PATH=${ONEDRIVE_IUCN}\AR\ShapesFinales
DEFAULT_GDB_PATH=${ONEDRIVE_IUCN}\AR\AR.gdb
APRX=${ONEDRIVE_IUCN}\AR\AR_EbA_Area.aprx
CSVPOINT_TO_GDB=${ONEDRIVE_IUCN}\AR\AR_Points.gdb
AR_MAP_NAME=AR_EbA_Area
